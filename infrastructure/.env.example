# Persona environment variables
# Copy this file to .env and fill in all values before starting the stack.
# Never commit .env to SCM.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=username
POSTGRES_PASSWORD=password         # replace with a strong password

# ── Hugging Face ─────────────────────────────────────────────────────
# Required to download models from HuggingFace Hub
HF_TOKEN=hf_your_token_here
