# inner-sanctum-infra — environment variables
# Copy this file to .env and fill in all values before starting the stack.
# Never commit .env to SCM.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=sanctum
POSTGRES_PASSWORD=changeme         # replace with a strong password

# ── vLLM / Hugging Face ─────────────────────────────────────────────────────
# Required to download Qwen2.5-14B-Instruct-GPTQ-Int4 from HuggingFace Hub
HF_TOKEN=hf_your_token_here
